# ===========================================================
# MXSuite — Environment Configuration
# ===========================================================
# Copy this file to .env and edit the values.
# NEVER commit .env to source control.
# ===========================================================

# ─── Database ─────────────────────────────────────────────
POSTGRES_DB=mxsuite
POSTGRES_USER=mxsuite
POSTGRES_PASSWORD=change_me_in_production

# ─── JWT Secret ───────────────────────────────────────────
# Must be at least 256 bits (32+ characters). Generate with:
#   openssl rand -base64 48
JWT_SECRET=change-this-to-a-secure-random-string-at-least-256-bits

# ─── Auth Mode ────────────────────────────────────────────
# local = username/password stored in PostgreSQL
# keycloak = external Keycloak IdP
AUTH_MODE=local

# ─── Bootstrap Admin ─────────────────────────────────────
# Created on first startup if no PLATFORM_ADMIN exists.
# Change the password immediately after first login.
MXSUITE_ADMIN_EMAIL=admin@mxsuite.com
MXSUITE_ADMIN_PASSWORD=Admin123!
MXSUITE_ADMIN_FIRST_NAME=Platform
MXSUITE_ADMIN_LAST_NAME=Admin

# ─── Email (SMTP) ────────────────────────────────────────
# Required for invitations and password reset emails.
# Leave defaults for local dev (emails will log to console).
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_AUTH=false
SMTP_STARTTLS=false
MXSUITE_EMAIL_FROM=noreply@mxsuite.com

# ─── Application ─────────────────────────────────────────
MXSUITE_BASE_URL=http://localhost

# ─── Port Mapping ────────────────────────────────────────
# Change if ports conflict with other services on your laptop
FRONTEND_PORT=80
POSTGRES_PORT_HOST=5432
REDIS_PORT_HOST=6379

# ─── Data Persistence (Production) ───────────────────────
# For production, uncomment and set to host paths:
# POSTGRES_DATA_PATH=C:/mxsuite-data/postgres
# REDIS_DATA_PATH=C:/mxsuite-data/redis
# FILE_STORAGE_PATH=C:/mxsuite-data/files
