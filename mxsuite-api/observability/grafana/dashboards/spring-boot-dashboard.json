{
  "annotations": { "list": [] },
  "editable": true,
  "panels": [
    {
      "title": "Request Rate (req/s)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "rate(http_server_requests_seconds_count{application=\"mxsuite-api\"}[1m])", "legendFormat": "{{method}} {{uri}} {{status}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps" } }
    },
    {
      "title": "Response Time P95",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{application=\"mxsuite-api\"}[5m]))", "legendFormat": "P95" },
        { "expr": "histogram_quantile(0.99, rate(http_server_requests_seconds_bucket{application=\"mxsuite-api\"}[5m]))", "legendFormat": "P99" },
        { "expr": "histogram_quantile(0.50, rate(http_server_requests_seconds_bucket{application=\"mxsuite-api\"}[5m]))", "legendFormat": "P50" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Error Rate (5xx)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "targets": [
        { "expr": "rate(http_server_requests_seconds_count{application=\"mxsuite-api\", status=~\"5..\"}[5m])", "legendFormat": "{{status}} {{uri}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "reqps", "color": { "mode": "fixed", "fixedColor": "red" } } }
    },
    {
      "title": "Requests by Status",
      "type": "piechart",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "targets": [
        { "expr": "sum by (status) (increase(http_server_requests_seconds_count{application=\"mxsuite-api\"}[1h]))", "legendFormat": "{{status}}" }
      ]
    },
    {
      "title": "Top Endpoints by Latency",
      "type": "bargauge",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "targets": [
        { "expr": "topk(10, histogram_quantile(0.95, rate(http_server_requests_seconds_bucket{application=\"mxsuite-api\"}[5m])))", "legendFormat": "{{method}} {{uri}}" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Hikari Connection Pool",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        { "expr": "hikaricp_connections_active{application=\"mxsuite-api\"}", "legendFormat": "Active" },
        { "expr": "hikaricp_connections_idle{application=\"mxsuite-api\"}", "legendFormat": "Idle" },
        { "expr": "hikaricp_connections_max{application=\"mxsuite-api\"}", "legendFormat": "Max" },
        { "expr": "hikaricp_connections_pending{application=\"mxsuite-api\"}", "legendFormat": "Pending" }
      ]
    },
    {
      "title": "Tomcat Threads",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        { "expr": "tomcat_threads_current_threads{application=\"mxsuite-api\"}", "legendFormat": "Current" },
        { "expr": "tomcat_threads_busy_threads{application=\"mxsuite-api\"}", "legendFormat": "Busy" },
        { "expr": "tomcat_threads_config_max_threads{application=\"mxsuite-api\"}", "legendFormat": "Max" }
      ]
    },
    {
      "title": "Active WebSocket Connections",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 0, "y": 24 },
      "targets": [
        { "expr": "mxsuite_websocket_connections_active{application=\"mxsuite-api\"}", "legendFormat": "Active" }
      ]
    },
    {
      "title": "Uptime",
      "type": "stat",
      "gridPos": { "h": 4, "w": 6, "x": 6, "y": 24 },
      "targets": [
        { "expr": "process_uptime_seconds{application=\"mxsuite-api\"}", "legendFormat": "Uptime" }
      ],
      "fieldConfig": { "defaults": { "unit": "s" } }
    },
    {
      "title": "Log Events Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        { "expr": "rate(logback_events_total{application=\"mxsuite-api\", level=\"error\"}[5m])", "legendFormat": "ERROR" },
        { "expr": "rate(logback_events_total{application=\"mxsuite-api\", level=\"warn\"}[5m])", "legendFormat": "WARN" },
        { "expr": "rate(logback_events_total{application=\"mxsuite-api\", level=\"info\"}[5m])", "legendFormat": "INFO" }
      ]
    }
  ],
  "schemaVersion": 39,
  "tags": ["spring-boot", "mxsuite", "api"],
  "templating": {
    "list": [
      { "name": "instance", "type": "query", "query": "label_values(http_server_requests_seconds_count{application=\"mxsuite-api\"}, instance)", "datasource": "Prometheus" }
    ]
  },
  "time": { "from": "now-1h", "to": "now" },
  "title": "MXSuite — Spring Boot API",
  "uid": "mxsuite-spring-boot"
}
