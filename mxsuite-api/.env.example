# ===========================================
# MXSuite API - Environment Configuration
# ===========================================
# Copy this file to .env and fill in the values
# NEVER commit the .env file to source control

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mxsuite
POSTGRES_USER=mxsuite
POSTGRES_PASSWORD=change_me_in_production

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT (for local auth mode)
JWT_SECRET=change-this-to-a-secure-random-string-at-least-256-bits

# Auth mode: local | keycloak
AUTH_MODE=local

# Keycloak (only needed if AUTH_MODE=keycloak)
KEYCLOAK_URL=http://localhost:8180
KEYCLOAK_ISSUER_URI=http://localhost:8180/realms/mxsuite
KEYCLOAK_JWK_SET_URI=http://localhost:8180/realms/mxsuite/protocol/openid-connect/certs

# File storage
STORAGE_TYPE=local
STORAGE_LOCAL_PATH=./data/files

# OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
OTEL_SERVICE_NAME=mxsuite-api

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USERNAME=noreply@example.com
SMTP_PASSWORD=change_me
SMTP_AUTH=true
SMTP_STARTTLS=true
MXSUITE_EMAIL_FROM=noreply@mxsuite.com

# Application
MXSUITE_BASE_URL=http://localhost:3000

# Bootstrap admin (created on first startup if no PLATFORM_ADMIN exists)
MXSUITE_ADMIN_EMAIL=admin@mxsuite.com
MXSUITE_ADMIN_PASSWORD=change_me_immediately
MXSUITE_ADMIN_FIRST_NAME=Platform
MXSUITE_ADMIN_LAST_NAME=Admin

# ===========================================
# Docker Volume Mounts (Production)
# ===========================================
# For production, set these to host paths so data persists
# on a mounted drive and is easy to back up.
# Leave commented for development (uses Docker named volumes).
#
# POSTGRES_DATA_PATH=/mnt/data/mxsuite/postgres
# REDIS_DATA_PATH=/mnt/data/mxsuite/redis
# FILE_STORAGE_PATH=/mnt/data/mxsuite/files
